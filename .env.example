# Railway mein yeh environment variables set karo
# (Railway dashboard → Variables tab)

# PostgreSQL connection string (Railway automatically deta hai PostgreSQL add karne pe)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Admin session secret (koi bhi random string rakho, 32+ characters)
SESSION_SECRET=change-this-to-a-random-secret-string-minimum-32-chars

# Railway automatically PORT set karta hai — mat karo manually
# PORT=3000
